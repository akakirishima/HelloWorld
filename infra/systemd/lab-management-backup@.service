[Unit]
Description=Lab Management SQLite backup for %i
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=%i
Group=%i
WorkingDirectory=/home/%i/Documents/HelloWorld/backend
EnvironmentFile=/home/%i/Documents/HelloWorld/.env.rpi
ExecStart=/home/%i/Documents/HelloWorld/backend/.venv/bin/python -m app.commands.backup_sqlite
