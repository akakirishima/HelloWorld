APP_ENV=production
APP_BASE_URL=http://raspberrypi.local:8088
CORS_ORIGINS=http://raspberrypi.local:8088
ALLOWED_SUBNETS=172.16.1.0/24
# If you use a NAS share from Raspberry Pi, point DATA_ROOT_PATH there.
# If you keep everything on Raspberry Pi, change these to /srv/lab-app/local/... .
DATA_ROOT_PATH=/mnt/lab-app-nas
SQLITE_PATH=/srv/lab-app/local/sqlite/local.db
BACKUP_ROOT_PATH=/mnt/lab-app-nas/backups
BACKUP_RETENTION_COUNT=7
SESSION_SECRET_KEY=change-me-for-production
AUTO_SEED=false
